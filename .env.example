# AI Sharpness Monitor — Environment Variables
# Copy to .env and fill in your values
# TOTAL COST: $0/month

# --- Cerebras API (FREE tier — https://cloud.cerebras.ai) ---
# Models available free: llama-3.3-70b, llama-3.1-8b
CEREBRAS_API_KEY=csk-...

# --- Telegram Bot (optional but recommended) ---
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# --- Database (SQLite local — no server needed) ---
DATABASE_URL=sqlite:///./data/sharpness.db

# --- Monitoring Config ---
PROBE_INTERVAL_MINUTES=15
ALERT_SCORE_DROP_THRESHOLD=15
CONTEXT_WARNING_PERCENT=60

# --- Models to Monitor (Cerebras free models) ---
# llama-3.3-70b is the flagship free model on Cerebras
MODELS=llama-3.3-70b,llama-3.1-8b

# --- Market Data (Binance public API — no key needed) ---
BTC_VOLATILITY_EXCHANGE=binance
VOLATILITY_WINDOW_MINUTES=60

# --- BTC Alert Thresholds ---
# Annualized volatility above this = possible AI load spike warning
BTC_VOLATILITY_HIGH_THRESHOLD=1.0
BTC_VOLATILITY_EXTREME_THRESHOLD=2.0
