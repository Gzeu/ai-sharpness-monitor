# AI Sharpness Monitor — Environment Variables
# Copy to .env and fill in your values

# --- API Keys ---
OPENROUTER_API_KEY=sk-or-v1-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
HELICONE_API_KEY=sk-helicone-...

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sharpness

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Monitoring Config ---
PROBE_INTERVAL_MINUTES=10
ALERT_SCORE_DROP_THRESHOLD=15
CONTEXT_WARNING_PERCENT=60

# --- Models to Monitor (comma-separated OpenRouter model IDs) ---
MODELS=anthropic/claude-sonnet-4-5,openai/gpt-4o,x-ai/grok-2,google/gemini-2.0-flash

# --- Market Data ---
BTC_VOLATILITY_EXCHANGE=binance
VOLATILITY_WINDOW_MINUTES=60
