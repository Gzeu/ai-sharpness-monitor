# AI Sharpness Monitor — environment configuration
# Copy to .env and fill in your values

# ── Required ────────────────────────────────────────────────────────────────
# Free API key from https://cloud.cerebras.ai (no credit card)
CEREBRAS_API_KEY=csk-your-key-here

# ── Optional: Telegram bot alerts ───────────────────────────────────────────
# 1. Create bot via @BotFather → get token
# 2. Send any message to your bot, then:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates  → find chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Probe settings ───────────────────────────────────────────────────────────
# How often to probe models (minutes). 15 is recommended.
PROBE_INTERVAL_MINUTES=15

# Models to probe — comma-separated Cerebras model IDs
# Available free: llama-3.3-70b, llama-3.1-8b
MODELS_TO_PROBE=llama-3.3-70b,llama-3.1-8b

# ── Alert thresholds ────────────────────────────────────────────────────────
# Telegram alert when score drops by this many points
ALERT_DROP_THRESHOLD=12
# Score below this always triggers alert (ignores cooldown)
CRITICAL_SCORE=35
# Minutes between repeat alerts per model
ALERT_COOLDOWN_MINUTES=30

# ── Market data ─────────────────────────────────────────────────────────────
# BTC/ETH volatility window in minutes (1m candles)
VOLATILITY_WINDOW_MINUTES=60
# Annualized volatility thresholds
BTC_VOLATILITY_HIGH_THRESHOLD=1.5
BTC_VOLATILITY_EXTREME_THRESHOLD=3.0

# ── Server ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
